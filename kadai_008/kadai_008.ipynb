        "import random\n",
        "\n",
        "# 0～20のランダムな整数\n",
        "var = random.randint(1, 20)\n",
        "\n",
        "# 値を表示\n",
        "print(var)\n",
        "\n",
        "# FizzBuzz判定\n",
        "if var % 3 == 0 and var % 5 == 0:\n",
        "    print(\"FizzBuzz\")\n",
        "elif var % 3 == 0:\n",
        "    print(\"Fizz\")\n",
        "elif var % 5 == 0:\n",
        "    print(\"Buzz\")\n",
        "else:\n",
        "    print(\"var\")"
      ],
